# GlassyVision — environment variables
# Complete list, verified against `grep process.env src/` on 2026-06-22.
# Copy to .env.local for dev, and set the same keys in Vercel for prod.

# --- Supabase (Step 1) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # secret — server only

# --- Shopify (Step 2) ---
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-token
SHOPIFY_ADMIN_ACCESS_TOKEN=your-admin-token        # secret
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret         # secret — HMAC verify
SHOPIFY_LOCATION_ID=your-location-id               # fulfillment location

# --- Resend (Step 3) ---
RESEND_API_KEY=your-resend-key                     # secret
RESEND_FROM_EMAIL=hello@glassyvision.com

# --- Sentry (Step 3) ---
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
# SENTRY_AUTH_TOKEN is optional, build-time only (source-map upload), not read at runtime.

# --- App secrets (Step 4): generate with `openssl rand -hex 32` ---
RX_TOKEN_SECRET=generate-a-random-64-char-hex-string     # signs Rx upload links
CLAIM_TOKEN_SECRET=generate-a-random-64-char-hex-string  # signs account-claim links
CRON_SECRET=generate-a-random-64-char-hex-string         # Bearer token for /api/cron/*

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000   # deployed URL in prod, e.g. https://glassyvision.vercel.app (no trailing slash)
